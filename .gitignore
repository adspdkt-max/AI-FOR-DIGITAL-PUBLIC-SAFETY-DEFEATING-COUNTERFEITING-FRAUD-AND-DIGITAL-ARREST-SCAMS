# ------------------------------
# Python Cache
# ------------------------------
__pycache__/
*.py[cod]
*$py.class

# ------------------------------
# Virtual Environments
# ------------------------------
venv/
.venv/
env/
ENV/

# ------------------------------
# Environment Variables
# ------------------------------
.env
.env.*

# ------------------------------
# IDE & Editor Settings
# ------------------------------
.vscode/
.idea/

# ------------------------------
# Operating System Files
# ------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------
# Build & Distribution
# ------------------------------
build/
dist/
*.egg-info/

# ------------------------------
# Jupyter Notebook
# ------------------------------
.ipynb_checkpoints/

# ------------------------------
# Logs
# ------------------------------
*.log

# ------------------------------
# Databases (Generated)
# ------------------------------
*.db
*.sqlite3

# ------------------------------
# Generated Reports
# ------------------------------
sentinel_report.pdf
latest_report.json
report_qr.png

# ------------------------------
# Test & Coverage
# ------------------------------
.pytest_cache/
.coverage
htmlcov/

# ------------------------------
# Static Analysis
# ------------------------------
.mypy_cache/

# ------------------------------
# PyInstaller
# ------------------------------
*.spec

# ------------------------------
# Temporary Files
# ------------------------------
*.tmp
*.temp
*.bak
*.swp

# ------------------------------
# Node.js (Future Frontend)
# ------------------------------
node_modules/
